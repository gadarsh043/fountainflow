# FountainFlow Environment Variables
# Copy this file to .env and fill in the values
# See next_steps.md for instructions on getting each key

# ──────────────────────────────────────────────
# DATABASE (provided by Docker Compose for local dev)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://fountainflow:fountainflow@localhost:5432/fountainflow

# ──────────────────────────────────────────────
# REDIS (provided by Docker Compose for local dev)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# STORAGE — S3 or MinIO (local dev uses MinIO via Docker Compose)
# For production: create an S3 bucket and IAM credentials
# ──────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=fountainflow-dev
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# For production S3 (comment out S3_ENDPOINT, uncomment these):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=fountainflow-production
# S3_REGION=us-east-1

# ──────────────────────────────────────────────
# AUTHENTICATION — Clerk (REQUIRED)
# Get these from https://dashboard.clerk.com
# ──────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# AI CHOREOGRAPHY (OPTIONAL)
# Used for AI-assisted section theme suggestions
# Get from https://console.anthropic.com
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────
# APPLICATION CONFIG
# ──────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
WORKER_PORT=8001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WORKER_URL=http://localhost:8001

# Processing limits
MAX_SONG_DURATION_SECONDS=2700
MAX_UPLOAD_SIZE_MB=200
WORKER_MEMORY_MB=4096
WORKER_TIMEOUT_SECONDS=1200

# ──────────────────────────────────────────────
# MONITORING (OPTIONAL — for production)
# ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
