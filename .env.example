# ============================================================
# FountainFlow Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://fountainflow:fountainflow@localhost:5432/fountainflow

# ── Redis (BullMQ job queue) ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Storage (MinIO locally, S3 in production) ───────────────
# For local dev with MinIO (docker-compose):
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=fountainflow-dev
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# For production S3:
# S3_ENDPOINT=  (leave blank for AWS S3)
# S3_BUCKET=fountainflow-prod
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Auth (Clerk) ────────────────────────────────────────────
# Get from https://dashboard.clerk.com → Your App → API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# For production (Netlify domain):
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── API Server ──────────────────────────────────────────────
API_PORT=3001
API_URL=http://localhost:3001

# ── Python Worker ──────────────────────────────────────────
WORKER_PORT=8001
WORKER_URL=http://localhost:8001

# Worker → API callback (used by Python worker to POST progress back to NestJS)
API_CALLBACK_URL=http://localhost:3001
# Shared secret between worker and API (leave blank in dev, set in prod)
API_INTERNAL_SECRET=change-me-in-production

# ── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Optional: AI-assisted choreography ─────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Job processing ─────────────────────────────────────────
JOB_TIMEOUT_MS=1200000  # 20 minutes
JOB_CONCURRENCY=2

# ── Security ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string-in-production

# ── File upload limits ─────────────────────────────────────
MAX_UPLOAD_SIZE_MB=200

# ── Environment ────────────────────────────────────────────
NODE_ENV=development
